# Supabase — auth + conversations/messages storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq — powers the Router and LLM narration (comprehensive/focused prompts)
GROQ_API_KEY=your-groq-api-key

# Python TA service — indicator computation (/compute, /capabilities, /resolve-symbol)
TA_BASE_URL=http://localhost:8000

# Zerodha KiteConnect — portfolio + broker integration
KITE_API_KEY=your-kite-api-key
KITE_API_SECRET=your-kite-api-secret

# Financial Modeling Prep — fundamentals fallback + symbols.json download script
FMP_API_KEY=your-fmp-api-key

# News — macro events panel
NEWS_API_KEY=your-newsapi-key
# TODO: replace with GNews (free tier supports server-side requests) — https://gnews.io

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
